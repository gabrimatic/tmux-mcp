{
  "name": "@gabrimatic/tmux-mcp",
  "version": "0.1.0",
  "description": "A tmux-backed MCP server that gives AI agents a persistent, human-attachable terminal.",
  "type": "module",
  "bin": {
    "tmux-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/*.test.js",
    "test:e2e": "npm run build && node --test tests/e2e.test.js",
    "lint": "eslint .",
    "check": "npm run typecheck && npm test",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tmux",
    "terminal",
    "agent",
    "codex"
  ],
  "author": "Soroush Yousefpour",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrimatic/tmux-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/gabrimatic/tmux-mcp/issues"
  },
  "homepage": "https://github.com/gabrimatic/tmux-mcp#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
